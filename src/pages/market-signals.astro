---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarketDashboard from '../components/MarketDashboard.tsx';
import '../styles/global.css';

import { getTranslation } from '../utils/i18n';
import { getMarketData } from './api/market-data';

const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);
const isID = lang === 'id';

const pageTitle = isID ? 'Pasar & Keuangan' : 'Markets & Finance';
const pageDesc = isID
  ? 'Terminal data finansial interaktif. Pantau pergerakan pasar global, grafik real-time, dan intelijen pasar.'
  : 'Interactive financial data terminal. Monitor global market movements, real-time charts, and market intelligence.';

// Fetch market data server-side
const data = await getMarketData();
const marketNews = data?.news ?? [];
const globalMetrics = data?.global ?? null;
const sentiment = data?.sentiment ?? null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.lazarusreport.online" },
    { "@type": "ListItem", "position": 2, "name": pageTitle, "item": "https://www.lazarusreport.online/market-signals" }
  ]
};
---

<BaseLayout
  title={`${pageTitle} — Lazarus Report Global`}
  description={pageDesc}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <Header />

  <main class="min-h-screen bg-lazarus-black text-lazarus-body font-sans pt-20 pb-16">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 pt-6 sm:pt-8 flex flex-col min-h-[calc(100vh-160px)]">

      <!-- ═══ Page Header ═══ -->
      <div class="mb-6 sm:mb-8 shrink-0">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-1.5 h-8 sm:h-10 bg-lazarus-gold rounded-full"></div>
          <div>
            <h1 class="font-serif text-2xl sm:text-3xl md:text-4xl text-lazarus-headline">{pageTitle}</h1>
            <p class="text-lazarus-muted text-xs sm:text-sm mt-1 max-w-xl">{pageDesc}</p>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- UNIFIED MARKET DASHBOARD TERMINAL -->
      <!-- ═══════════════════════════════════════════════ -->
      <section class="flex-1 flex flex-col mb-8 sm:mb-10">
        <MarketDashboard 
          client:load 
          lang={lang} 
          news={marketNews} 
          global={globalMetrics} 
          sentiment={sentiment} 
        />
      </section>

      <!-- SECTION: Economic Calendar (Moved to bottom) -->
      <section class="mb-8 shrink-0">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-serif text-lg sm:text-xl text-lazarus-headline flex items-center gap-3">
            <div class="w-1 h-5 bg-lazarus-gold rounded-full"></div>
            {isID ? 'Kalender Ekonomi Global' : 'Global Economic Calendar'}
          </h2>
        </div>
        <div class="bg-[#121212] border border-lazarus-border/30 rounded-xl overflow-hidden p-2">
          <iframe
            src="https://s.tradingview.com/embed-widget/events/?locale=en#%7B%22colorTheme%22%3A%22dark%22%2C%22isTransparent%22%3Atrue%2C%22width%22%3A%22100%25%22%2C%22height%22%3A420%2C%22importanceFilter%22%3A%22012%22%2C%22countryFilter%22%3A%22us%2Ccn%2Cjp%2Cgb%2Ceu%2Cid%22%7D"
            class="w-full border-0"
            style="height: 420px;"
            loading="lazy"
            title="Economic Calendar"
            sandbox="allow-scripts allow-same-origin allow-popups"
          ></iframe>
        </div>
      </section>

      <!-- Disclaimer -->
      <div class="shrink-0 bg-lazarus-dark/20 border border-lazarus-border/20 rounded-xl p-5 text-center">
        <p class="text-lazarus-muted/50 text-[10px] leading-relaxed italic">
          Market Intelligence Terminal. All data points, including charts and news, are provided for informational purposes only. Lazarus Report Global does not provide financial or investment advice.
        </p>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  section { animation: fade-in 0.8s ease-out forwards; }
</style>
