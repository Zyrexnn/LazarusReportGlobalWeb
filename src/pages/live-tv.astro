---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import LiveTV from '../components/LiveTV.astro';
import '../styles/global.css';
import { getTranslation } from '../utils/i18n';

const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);
---

<BaseLayout
  title={`${t.pages.liveTv.title} - Lazarus Report Global`}
  description={t.pages.liveTv.metaDescription}
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <section class="relative mb-12 overflow-hidden rounded-[2rem] border border-lazarus-gold-dark/20 bg-[linear-gradient(135deg,rgba(212,175,55,0.05),rgba(15,15,15,0.98)_50%,rgba(15,15,15,1))] px-6 py-12 sm:px-12">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(212,175,55,0.05),transparent_40%)]"></div>
      <div class="relative z-10">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-lazarus-gold/70">Signal Monitoring Desk</p>
        <h1 class="mt-4 max-w-3xl font-serif text-4xl text-lazarus-headline sm:text-5xl lg:text-6xl tracking-tight leading-[1.1]">
          {t.pages.liveTv.title}
        </h1>
        <p class="mt-6 max-w-2xl text-[15px] leading-relaxed text-lazarus-muted/90 font-light sm:text-lg">
          {t.pages.liveTv.description}
        </p>
        <div class="mt-8 flex items-center gap-4">
          <span class="h-px w-12 bg-lazarus-gold/30"></span>
          <span class="text-[9px] font-bold uppercase tracking-[0.3em] text-lazarus-gold/50">Production Ready Feed</span>
        </div>
      </div>
    </section>

    <LiveTV title="Global Stream Monitor" />
  </main>

  <Footer />
</BaseLayout>
