 ---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import { getTranslation } from '../utils/i18n';
const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);
---

<BaseLayout
  title={`${t.about.title} — Lazarus Report Global`}
  description={t.about.philosophyText}
>
  <Header />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Logo & Brand -->
    <div class="text-center mb-16 animate-fade-in">
      <img
        src="/logolazarusreport.png"
        alt="Lazarus Report Global"
        class="h-32 w-auto mx-auto mb-6"
        loading="eager"
        decoding="async"
      />
      <p class="text-lazarus-gold text-sm tracking-[0.3em] uppercase mt-4 font-medium">
        {t.footer.description.split('.')[0]}
      </p>
    </div>

    <!-- Content Sections -->
    <div class="space-y-12">
      <!-- Who We Are -->
      <section class="animate-fade-in" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">{t.about.whoWeAreTitle}</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <p class="text-lazarus-body leading-relaxed mb-4 text-balance">
            {t.about.whoWeAreText}
          </p>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">{t.about.philosophyTitle}</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <p class="text-lazarus-body leading-relaxed mb-4">
            {t.about.philosophyText}
          </p>
        </div>
      </section>

      <!-- What We Cover -->
      <section class="animate-fade-in" style="animation-delay: 0.3s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">{t.about.coverageTitle}</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <p class="text-lazarus-body leading-relaxed mt-2 text-balance">
            {t.about.coverageText}
          </p>
        </div>
      </section>

      <!-- Commitment -->
      <section class="animate-fade-in" style="animation-delay: 0.4s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">{t.about.commitmentTitle}</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5 space-y-3">
          <p class="text-lazarus-body leading-relaxed text-balance">
            {t.about.commitmentText}
          </p>
        </div>
      </section>

      <!-- Disclaimer -->
      <section class="animate-fade-in" style="animation-delay: 0.5s;">
        <div class="bg-lazarus-dark border border-lazarus-border rounded-xl p-6">
          <h3 class="text-lazarus-headline text-sm font-bold tracking-wider uppercase mb-3">Disclaimer</h3>
          <p class="text-lazarus-muted text-sm leading-relaxed">
            {t.about.disclaimer}
          </p>
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center animate-fade-in" style="animation-delay: 0.6s;">
        <div class="border-t border-lazarus-border pt-10">
          <p class="text-lazarus-body text-lg mb-6">{t.about.followCta}</p>
          <a
            href="https://www.instagram.com/lazarusreportglobal/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-8 py-4 bg-lazarus-gold text-lazarus-black font-bold text-sm tracking-wider uppercase rounded-xl hover:bg-lazarus-gold-light transition-colors duration-200 touch-target"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
            @lazarusreportglobal
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
