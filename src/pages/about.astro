---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="About — Lazarus Report Global"
  description="Independent Geopolitical Analysis & Global Security. Uncovering the buried truths behind global power shifts."
>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Logo & Brand -->
    <div class="text-center mb-16 animate-fade-in">
      <svg viewBox="0 0 48 48" class="w-20 h-20 text-lazarus-gold mx-auto mb-6" fill="currentColor">
        <path d="M24 4C24 4 18 10 16 16C14 22 16 26 18 28C14 24 10 22 8 18C8 18 8 26 14 32C18 36 22 38 24 44C26 38 30 36 34 32C40 26 40 18 40 18C38 22 34 24 30 28C32 26 34 22 32 16C30 10 24 4 24 4Z" />
        <path d="M24 14C24 14 21 18 20 22C19 26 21 28 22 29C22 29 20 26 21 22C22 18 24 14 24 14Z" opacity="0.5" />
        <path d="M24 14C24 14 27 18 28 22C29 26 27 28 26 29C26 29 28 26 27 22C26 18 24 14 24 14Z" opacity="0.5" />
      </svg>
      <div class="inline-block">
        <div class="border-t border-lazarus-gold-dark mb-2"></div>
        <h1 class="font-serif text-4xl sm:text-5xl tracking-[0.15em] text-lazarus-headline font-bold">
          LAZARUS <span class="text-lazarus-gold">REPORT</span>
        </h1>
        <div class="border-b border-lazarus-gold-dark mt-2"></div>
      </div>
      <p class="text-lazarus-gold text-sm tracking-[0.3em] uppercase mt-4 font-medium">
        Independent Geopolitical Analysis & Global Security
      </p>
    </div>

    <!-- Content Sections -->
    <div class="space-y-12">
      <!-- Who We Are -->
      <section class="animate-fade-in" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">Who We Are</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <p class="text-lazarus-body leading-relaxed mb-4">
            <strong class="text-lazarus-headline">Lazarus Report Global</strong> is an independent civilian media platform dedicated to delivering rigorous geopolitical analysis, global security intelligence, and financial market insights.
          </p>
          <p class="text-lazarus-body leading-relaxed">
            We are not affiliated with any government, military, political party, or corporate entity. Our commitment is solely to the truth and to the public's right to informed understanding of world events.
          </p>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">Our Philosophy</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <p class="text-lazarus-body leading-relaxed mb-4">
            The name <strong class="text-lazarus-gold">"Lazarus"</strong> symbolizes <em>rebirth and resurrection</em> — a resurrection of information. In an era of propaganda, censorship, and selective narratives, we exist to dig up and revive the buried truths that shape our world.
          </p>
          <blockquote class="border-l-2 border-lazarus-gold pl-4 italic text-lazarus-body/80 my-6">
            "Uncovering the buried truths behind global power shifts."
          </blockquote>
          <p class="text-lazarus-body leading-relaxed">
            We believe that every citizen deserves access to clear, unbiased analysis of the forces shaping geopolitics, military strategy, economic corridors, and global finance.
          </p>
        </div>
      </section>

      <!-- What We Cover -->
      <section class="animate-fade-in" style="animation-delay: 0.3s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">What We Cover</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">Geopolitics</h3>
              <p class="text-lazarus-muted text-sm">Power dynamics, alliances, diplomatic shifts, and international relations.</p>
            </div>
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">Military & Defense</h3>
              <p class="text-lazarus-muted text-sm">Force deployments, defense strategies, weapons systems, and conflicts.</p>
            </div>
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">Energy & Oil</h3>
              <p class="text-lazarus-muted text-sm">OPEC dynamics, energy corridors, oil markets, and resource competition.</p>
            </div>
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">Markets & Crypto</h3>
              <p class="text-lazarus-muted text-sm">Financial markets, cryptocurrency, institutional flows, and macro trends.</p>
            </div>
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">AIS Ship Tracking</h3>
              <p class="text-lazarus-muted text-sm">Live AIS maritime vessel tracking in strategic waterways worldwide.</p>
            </div>
            <div class="bg-lazarus-dark border border-lazarus-border rounded-lg p-4">
              <h3 class="text-lazarus-gold text-sm font-bold tracking-wider uppercase mb-2">Deep Analysis</h3>
              <p class="text-lazarus-muted text-sm">Long-form intelligence reports and investigative analysis.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Commitment -->
      <section class="animate-fade-in" style="animation-delay: 0.4s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-lazarus-gold rounded-full"></div>
          <h2 class="font-serif text-2xl text-lazarus-headline">Our Commitment</h2>
        </div>
        <div class="pl-6 border-l border-lazarus-border ml-0.5 space-y-3">
          <div class="flex items-start gap-3">
            <span class="text-lazarus-gold mt-1">◆</span>
            <p class="text-lazarus-body"><strong class="text-lazarus-headline">Independence</strong> — We operate free from government and corporate influence.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-lazarus-gold mt-1">◆</span>
            <p class="text-lazarus-body"><strong class="text-lazarus-headline">Transparency</strong> — We cite sources and distinguish fact from analysis.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-lazarus-gold mt-1">◆</span>
            <p class="text-lazarus-body"><strong class="text-lazarus-headline">Accuracy</strong> — We prioritize verified information and correct errors promptly.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-lazarus-gold mt-1">◆</span>
            <p class="text-lazarus-body"><strong class="text-lazarus-headline">Accessibility</strong> — Complex geopolitics translated into clear, accessible language.</p>
          </div>
        </div>
      </section>

      <!-- Disclaimer -->
      <section class="animate-fade-in" style="animation-delay: 0.5s;">
        <div class="bg-lazarus-dark border border-lazarus-border rounded-xl p-6">
          <h3 class="text-lazarus-headline text-sm font-bold tracking-wider uppercase mb-3">Disclaimer</h3>
          <p class="text-lazarus-muted text-sm leading-relaxed">
            All content published by Lazarus Report Global is for <strong class="text-lazarus-body">informational and educational purposes only</strong>. Nothing on this platform constitutes financial advice, investment recommendations, legal counsel, or strategic guidance. Readers are encouraged to conduct their own research and consult qualified professionals before making any decisions based on our reporting.
          </p>
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center animate-fade-in" style="animation-delay: 0.6s;">
        <div class="border-t border-lazarus-border pt-10">
          <p class="text-lazarus-body text-lg mb-6">Follow our work and join the conversation.</p>
          <a
            href="https://www.instagram.com/lazarusreportglobal/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-8 py-4 bg-lazarus-gold text-lazarus-black font-bold text-sm tracking-wider uppercase rounded-xl hover:bg-lazarus-gold-light transition-colors duration-200 touch-target"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
            @lazarusreportglobal
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
