---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import CryptoTicker from '../components/CryptoTicker.tsx';
import '../styles/global.css';
---

<BaseLayout
  title="Markets & Finance — Lazarus Report Global"
  description="Live market data, financial analysis, cryptocurrency tracking, and global economic intelligence."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Page Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-10 bg-green-400 rounded-full"></div>
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl text-lazarus-headline">Markets & Finance</h1>
          <p class="text-lazarus-muted text-sm mt-1">Global markets, crypto, oil, and financial intelligence.</p>
        </div>
      </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- News Feed -->
      <div class="flex-1 lg:w-[70%]">
        <NewsFeed client:load initialCategory="Markets" />
      </div>

      <!-- Sidebar -->
      <div class="lg:w-[30%] lg:sticky lg:top-24 lg:self-start space-y-6">
        <CryptoTicker client:load />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
