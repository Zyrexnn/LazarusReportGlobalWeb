---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AISMap from '../components/AISMap.tsx';
import '../styles/global.css';
---

<BaseLayout
  title="AIS Ship Tracker — Lazarus Report Global"
  description="Live AIS vessel tracking in the Persian Gulf, Strait of Hormuz, and strategic maritime chokepoints."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Page Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-10 bg-lazarus-gold rounded-full"></div>
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl text-lazarus-headline">AIS Ship Tracker</h1>
          <p class="text-lazarus-muted text-sm mt-1">Live vessel tracking — Persian Gulf, Strait of Hormuz & strategic waterways.</p>
        </div>
      </div>
    </div>

    <!-- Info Bar -->
    <div class="flex flex-wrap items-center gap-4 mb-6 text-sm">
      <div class="flex items-center gap-2 text-lazarus-body">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
        </span>
        Live tracking active
      </div>
      <span class="text-lazarus-muted/30">|</span>
      <span class="text-lazarus-muted">Region: Persian Gulf & Bahrain</span>
      <span class="text-lazarus-muted/30">|</span>
      <span class="text-lazarus-muted">Bounding Box: 24°–28°N, 48°–58°E</span>
    </div>

    <!-- Full Page Map -->
    <AISMap client:only="react" fullPage={true} />

    <!-- Legend -->
    <div class="mt-6 bg-lazarus-dark border border-lazarus-border rounded-xl p-4">
      <h3 class="text-lazarus-gold text-xs font-bold tracking-wider uppercase mb-3">Map Legend</h3>
      <div class="flex flex-wrap gap-6 text-sm text-lazarus-muted">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-lazarus-gold" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L4 20h16L12 2zm0 4l5 12H7l5-12z"/>
          </svg>
          Active Vessel
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-green-400 inline-block"></span>
          Underway
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span>
          Anchored
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span>
          Not Under Command
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-lazarus-muted/40 text-xs mt-4">
      AIS data is provided for informational purposes only. Position data may be delayed or incomplete. Vessel information sourced from AISStream.io.
    </p>
  </main>

  <Footer />
</BaseLayout>
