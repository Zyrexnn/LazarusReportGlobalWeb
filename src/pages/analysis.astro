---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import '../styles/global.css';
---

<BaseLayout
  title="Analysis — Lazarus Report Global"
  description="In-depth analytical reports on geopolitics, security, economics, and global trends."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-10 bg-lazarus-gold rounded-full"></div>
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl text-lazarus-headline">Analysis</h1>
          <p class="text-lazarus-muted text-sm mt-1">Long-form intelligence reports and investigative deep-dives.</p>
        </div>
      </div>
    </div>
    <NewsFeed client:load initialCategory="All" />
  </main>

  <Footer />
</BaseLayout>
