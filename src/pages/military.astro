---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import '../styles/global.css';
---

<BaseLayout
  title="Military & Defense — Lazarus Report Global"
  description="Military deployments, defense strategy, weapons systems, and conflict analysis."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-10 bg-blue-400 rounded-full"></div>
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl text-lazarus-headline">Military & Defense</h1>
          <p class="text-lazarus-muted text-sm mt-1">Force deployments, defense strategies, and global conflict analysis.</p>
        </div>
      </div>
    </div>
    <NewsFeed client:load initialCategory="Military" />
  </main>

  <Footer />
</BaseLayout>
