---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import CryptoTicker from '../components/CryptoTicker.tsx';
import '../styles/global.css';

import { getTranslation } from '../utils/i18n';
const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);
---

<BaseLayout
  title={`${t.pages.crypto.title} — Lazarus Report Global`}
  description={t.pages.crypto.metaDescription}
  keywords="cryptocurrency, crypto markets, bitcoin, ethereum, blockchain, digital assets, crypto analysis, cryptocurrency news"
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-10 bg-purple-400 rounded-full"></div>
        <div>
          <h1 class="font-serif text-3xl sm:text-4xl text-lazarus-headline">{t.pages.crypto.title}</h1>
          <p class="text-lazarus-muted text-sm mt-1">{t.pages.crypto.description}</p>
        </div>
      </div>
    </div>
    <div class="flex flex-col lg:flex-row gap-8">
      <div class="flex-1 lg:w-[70%]">
        <NewsFeed client:load initialCategory="Crypto" lang={lang} />
      </div>
      <div class="lg:w-[30%] lg:sticky lg:top-24 lg:self-start space-y-6">
        <CryptoTicker client:load lang={lang} />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
