---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-lazarus-border bg-lazarus-black mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <svg viewBox="0 0 48 48" class="w-8 h-8 text-lazarus-gold" fill="currentColor">
            <path d="M24 4C24 4 18 10 16 16C14 22 16 26 18 28C14 24 10 22 8 18C8 18 8 26 14 32C18 36 22 38 24 44C26 38 30 36 34 32C40 26 40 18 40 18C38 22 34 24 30 28C32 26 34 22 32 16C30 10 24 4 24 4Z" />
          </svg>
          <span class="font-serif text-lg tracking-[0.2em] text-lazarus-headline font-bold">
            LAZARUS <span class="text-lazarus-gold">REPORT</span>
          </span>
        </div>
        <p class="text-lazarus-muted text-sm leading-relaxed max-w-xs">
          Independent Geopolitical Analysis & Global Security. Uncovering the buried truths behind global power shifts.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lazarus-gold text-sm font-semibold tracking-wider uppercase mb-4">Coverage</h4>
        <ul class="space-y-2">
          <li><a href="/geopolitics" class="text-lazarus-muted hover:text-lazarus-gold text-sm transition-colors">Geopolitics</a></li>
          <li><a href="/military" class="text-lazarus-muted hover:text-lazarus-gold text-sm transition-colors">Military & Defense</a></li>
          <li><a href="/markets" class="text-lazarus-muted hover:text-lazarus-gold text-sm transition-colors">Markets & Finance</a></li>
          <li><a href="/ship-tracker" class="text-lazarus-muted hover:text-lazarus-gold text-sm transition-colors">Ship Tracker</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-lazarus-gold text-sm font-semibold tracking-wider uppercase mb-4">Connect</h4>
        <a
          href="https://www.instagram.com/lazarusreportglobal/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-lazarus-muted hover:text-lazarus-gold text-sm transition-colors touch-target"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
          </svg>
          @lazarusreportglobal
        </a>
        <div class="mt-6">
          <p class="text-lazarus-muted/60 text-xs leading-relaxed">
            All content is for informational purposes only and does not constitute financial, legal, or strategic advice.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-lazarus-border mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-lazarus-muted/50 text-xs">
        &copy; {currentYear} Lazarus Report Global. All rights reserved.
      </p>
      <div class="flex items-center gap-1 text-xs text-lazarus-muted/40">
        <span>Built with</span>
        <svg class="w-3 h-3 text-lazarus-gold" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
        <span>for truth</span>
      </div>
    </div>
  </div>
</footer>
