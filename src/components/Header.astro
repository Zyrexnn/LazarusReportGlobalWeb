---
// Phoenix Logo SVG Component
// Premium header with sticky navigation, mobile hamburger, and search
import LanguageToggle from './LanguageToggle';
import MarketTicker from './MarketTicker';
import { getTranslation } from '../utils/i18n';

const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);

const navItems = [
  { href: '/', label: t.nav.home },
  { href: '/live-tv', label: t.nav.liveTv },
  { href: '/ship-tracker', label: t.nav.shipTracker },
  { href: '/flight-tracker', label: t.nav.flightTracker },
  { href: '/analysis', label: t.nav.analysis },
  { href: '/about', label: t.nav.about },
];

const currentPath = Astro.url.pathname;
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 glass-dark border-b border-lazarus-border">
  <!-- Market Ticker Bar -->
  <MarketTicker client:load />

  <!-- Main Navigation Bar -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group" id="logo-link">
        <img
          src="/logolazarusreport.png"
          alt="Lazarus Report Global"
          class="h-32 py-1 w-auto transition-transform duration-300 group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium tracking-wide transition-colors duration-200 rounded-md touch-target',
              currentPath === item.href
                ? 'text-lazarus-gold bg-lazarus-gold/10'
                : 'text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Right side: Search + Mobile Menu -->
      <div class="flex items-center gap-2">
        <!-- Language Toggle -->
        <LanguageToggle client:load initialLang={lang} />

        <!-- Search Button -->
        <button
          id="search-toggle"
          class="touch-target rounded-md text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5 transition-colors ml-2"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden touch-target rounded-md text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-lazarus-border bg-lazarus-black/95 backdrop-blur-md">
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-3 text-base font-medium rounded-lg transition-colors touch-target',
            currentPath === item.href
              ? 'text-lazarus-gold bg-lazarus-gold/10'
              : 'text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="hidden fixed inset-0 z-[60] bg-lazarus-black/95 backdrop-blur-xl">
    <div class="max-w-2xl mx-auto px-4 pt-24">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-lazarus-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder={t.sections.searchPlaceholder}
          class="w-full pl-12 pr-4 py-4 bg-lazarus-dark border border-lazarus-border rounded-xl text-lazarus-headline placeholder-lazarus-muted text-lg focus:outline-none focus:border-lazarus-gold transition-colors"
        />
        <button
          id="search-close"
          class="absolute right-4 top-1/2 -translate-y-1/2 touch-target text-lazarus-muted hover:text-lazarus-gold transition-colors"
          aria-label="Close search"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <p class="text-lazarus-muted text-sm mt-4 text-center">Press ESC to close</p>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[112px]"></div>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  menuToggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Search modal
  const searchToggle = document.getElementById('search-toggle');
  const searchModal = document.getElementById('search-modal');
  const searchClose = document.getElementById('search-close');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  searchToggle?.addEventListener('click', () => {
    searchModal?.classList.remove('hidden');
    searchInput?.focus();
    document.body.style.overflow = 'hidden';
  });

  const closeSearch = () => {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  searchClose?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
  });

  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeSearch();
  });
</script>
