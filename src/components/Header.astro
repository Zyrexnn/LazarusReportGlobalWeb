---
// Phoenix Logo SVG Component
// Premium header with sticky navigation, mobile hamburger, and search
import LanguageToggle from './LanguageToggle';
import MarketTicker from './MarketTicker';
import { getTranslation } from '../utils/i18n';

const lang = Astro.cookies.get('lazarus_lang')?.value || 'en';
const t = getTranslation(lang);

const navItems = [
  { href: '/', label: t.nav.home },
  { href: '/live-tv', label: t.nav.liveTv },
  { href: '/ship-tracker', label: t.nav.shipTracker },
  { href: '/flight-tracker', label: t.nav.flightTracker },
  { href: '/conflict-tracker', label: t.nav.conflictTracker },
  { href: '/analysis', label: t.nav.analysis },
  { href: '/about', label: t.nav.about },
];

const currentPath = Astro.url.pathname;
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 glass-dark border-b border-lazarus-border">
  <!-- Market Ticker Bar -->
  <MarketTicker client:load />

  <!-- Main Navigation Bar -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group" id="logo-link">
        <img
          src="/logolazarusreport.png"
          alt="Lazarus Report Global"
          class="h-32 py-1 w-auto transition-transform duration-300 group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium tracking-wide transition-colors duration-200 rounded-md touch-target',
              currentPath === item.href
                ? 'text-lazarus-gold bg-lazarus-gold/10'
                : 'text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Right side: Search + Mobile Menu -->
      <div class="flex items-center gap-2">
        <!-- Language Toggle -->
        <LanguageToggle client:load initialLang={lang} />

        <!-- Search Button -->
        <button
          id="search-toggle"
          class="touch-target rounded-md text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5 transition-colors ml-2"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden touch-target rounded-md text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-lazarus-border bg-lazarus-black/95 backdrop-blur-md">
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-3 text-base font-medium rounded-lg transition-colors touch-target',
            currentPath === item.href
              ? 'text-lazarus-gold bg-lazarus-gold/10'
              : 'text-lazarus-body hover:text-lazarus-gold hover:bg-lazarus-gold/5',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="hidden fixed inset-0 z-[60] bg-lazarus-black/95 backdrop-blur-xl">
    <div class="max-w-2xl mx-auto px-4 pt-24">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-lazarus-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder={t.sections.searchPlaceholder}
          class="w-full pl-12 pr-4 py-4 bg-lazarus-dark border border-lazarus-border rounded-xl text-lazarus-headline placeholder-lazarus-muted text-lg focus:outline-none focus:border-lazarus-gold transition-colors"
        />
        <button
          id="search-close"
          class="absolute right-4 top-1/2 -translate-y-1/2 touch-target text-lazarus-muted hover:text-lazarus-gold transition-colors"
          aria-label="Close search"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="search-results" class="mt-4 flex flex-col gap-2 max-h-[50vh] overflow-y-auto custom-scrollbar"></div>
      <p class="text-lazarus-muted text-sm mt-4 text-center">Press ESC to close, or ENTER to search full news feed</p>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[112px]"></div>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  menuToggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Search modal
  const searchToggle = document.getElementById('search-toggle');
  const searchModal = document.getElementById('search-modal');
  const searchClose = document.getElementById('search-close');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  searchToggle?.addEventListener('click', () => {
    searchModal?.classList.remove('hidden');
    searchInput?.focus();
    document.body.style.overflow = 'hidden';
  });

  const closeSearch = () => {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  searchClose?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
  });

  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeSearch();
  });

  // Live Search Logic with Debounce
  const searchResultsContainer = document.getElementById('search-results');
  let searchTimeout = setTimeout(() => {}, 0);

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.trim();
    
    // Clear previous results container immediately
    if (!query) {
      if (searchResultsContainer) searchResultsContainer.innerHTML = '';
      clearTimeout(searchTimeout);
      return;
    }

    if (searchResultsContainer) searchResultsContainer.innerHTML = '<p class="text-lazarus-muted text-center animate-pulse py-4">Searching...</p>';

    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(async () => {
      try {
        const lang = document.documentElement.lang === 'id' ? 'id' : 'en';
        const res = await fetch(`/api/news?q=${encodeURIComponent(query)}&lang=${lang}`);
        if (!res.ok) throw new Error();
        const data = await res.json();
        const articles = data.articles?.slice(0, 5) || []; // Top 5 results

        if (articles.length === 0) {
          if (searchResultsContainer) searchResultsContainer.innerHTML = '<p class="text-lazarus-muted text-center py-4">No results found.</p>';
          return;
        }

        if (searchResultsContainer) {
          searchResultsContainer.innerHTML = articles.map((article: any) => `
            <a href="${article.url}" target="_blank" rel="noopener" class="block p-3 bg-lazarus-black/50 border border-lazarus-border rounded-lg hover:border-lazarus-gold/50 hover:bg-lazarus-black transition-colors group">
              <span class="text-[10px] font-bold tracking-widest uppercase text-lazarus-black bg-lazarus-gold px-1.5 py-0.5 rounded-sm inline-block mb-1">
                ${article.category || 'News'}
              </span>
              <h4 class="text-lazarus-headline text-sm font-semibold group-hover:text-lazarus-gold transition-colors line-clamp-1">${article.title}</h4>
              <p class="text-lazarus-muted text-xs mt-1 line-clamp-1">${article.excerpt}</p>
            </a>
          `).join('');
        }
      } catch (err) {
        if (searchResultsContainer) searchResultsContainer.innerHTML = '<p class="text-red-400 text-center py-4 text-sm whitespace-pre-wrap">Failed to load search results.</p>';
      }
    }, 400); // 400ms debounce
  });

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const query = searchInput.value.trim();
      if (query) {
        window.location.href = `/?q=${encodeURIComponent(query)}`;
      }
    }
  });
</script>
